---
import Header from "./form/Header.astro";
import Body from "./form/Body.astro";
import Text from "./form/Text.astro";
import TextArea from "./form/TextArea.astro";
import Checkbox from "./form/Checkbox.astro";
import File from "./form/File.astro";
import Select from "./form/Select.astro";
import Button from "./form/Button.astro";
interface Props extends Settings {}
const settings = Astro.props;
settings.url = `${Astro.url.protocol}//${Astro.url.host}`;
const sizes = [
  { label: "Mini", value: "mini"},
  { label: "Tiny", value: "tiny"},
  { label: "Small", value: "small"},
  { label: "Medium", value: "medium"},
  { label: "Large", value: "large"},
  { label: "Big", value: "big"},
  { label: "Huge", value: "huge"},
  { label: "Massive", value: "massive"},
];
const schemas = [
  { label: "Organization", value: "organization" },
];
const openGraph = [
  { label: "Website", value: "website" },
  { label: "Profile", value: "profile" },
];
const colors = [
  { value: "", label: "", },
  { value: "amber", label: "Amber" },
  { value: "black", label: "Black" },
  { value: "blue", label: "Blue" },
  { value: "cyan", label: "Cyan" },
  { value: "emerald", label: "Emerald" },
  { value: "fuchsia", label: "Fuchsia" },
  { value: "green", label: "Green" },
  { value: "grey", label: "Grey" },
  { value: "indigo", label: "Indigo" },
  { value: "lime", label: "Lime" },
  { value: "orange", label: "Orange" },
  { value: "pink", label: "Pink" },
  { value: "purple", label: "Purple" },
  { value: "red", label: "Red" },
  { value: "rose", label: "Rose" },
  { value: "slate", label: "Slate" },
  { value: "sky", label: "Sky" },
  { value: "teal", label: "Teal" },
  { value: "violet", label: "Violet" },
  { value: "yellow", label: "Yellow" },
];
---

<script is:inline define:vars={{settings}}>
  window.settings = {
    title: { value: settings.title?.value || '', visible: settings.title?.visible || false },
    location: { value: settings.location?.value || '', visible: settings.location?.visible || false },
    description: { value: settings.description?.value || '', visible: settings.description?.visible || false },
    url: settings.url || '',
    image: {
      src: settings.image?.src || '',
      alt: settings.image?.alt || '',
      size: settings.image?.size || 'medium'
    },
    links: settings.links && settings.links.length > 0 ? settings.links : [{title: '', href: '', icon: '', color: ''}],
    type: settings.type || 'Organization',
    og: settings.og || 'website',
    author: { name: settings.author?.name || '', email: settings.author?.email || '' }
  };
</script>

<div class="max-w-4xl mx-auto space-y-0 text-sm" >
  <form x-data="window.settings" x-on:image-uploaded.window="image.src = $event.detail.path">
    <Header title="Content" description="Content is visible and the main component of the home page." position="top"/>
    <Body>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <Text label="Title" key="title.value" required />
        <Text label="Location" key="location.value" required />
        <Text label="URL" key="url" disabled />
      </div>
      <TextArea label="Desciption" key="description.value" required />
      <div class="flex gap-6 py-2">
        <Checkbox label="Show Title" key="title.visible" />
        <Checkbox label="Show Description" key="description.visible" />
        <Checkbox label="Show Location" key="location.visible" />
      </div>
  
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <File label="Image" key="image" onChange="window.handleImageUpload($event.target)" />
        <Text label="Alt" key="image.alt" />
        <Select label="Size" key="image.size" options={sizes}/>
      </div>
      <Text label="Source" key="image.src" />
    </Body>
    
    <Header title="Links" description="Add or remove links that appear beneath the main content.">
      <Button label="Add" key="add-link" onClick="links.push({title: '', href: '', icon: '', color: ''})" />
    </Header>
    <Body>
      <div id="links-container" class="space-y-4">
        <template x-for="(link, index) in links" :key="index">
          <div class="link-item p-4 border border-gray-200 rounded bg-gray-50">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
              <Text label="Title" key="link.title" />
              <Text label="URL" key="link.href" />
              <Text label="Icon" key="link.icon" />
              <Select label="Color" key="link.color" options={colors} />
            </div>
            <div class="flex justify-end mt-3">
              <Button label="Remove" key="remove-link" onClick="links.splice(index, 1)" type="Secondary" />
            </div>
          </div>
        </template>
      </div>
    </Body>

    <Header title="Metadata" description="Metadata is hidden from view used in search results and social posting."/>
    <Body>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <Text label="Author Name" key="author.name" required />
        <Text label="Author Email" key="author.email" required />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <Select label="Schema Type" key="type" options={schemas}/>
        <Select label="OpenGraph Type" key="og" options={openGraph}/>
      </div>
    </Body>
    <Header position="bottom">
      <Button label="Cancel" key="cancel" onClick="" type="Secondary" />
      <Button label="Save" key="save" onClick="window.handleSave(window.settings)" />
    </Header>
  </form>
</div>

<script>
  // @ts-expect-error
  window.handleSave = async function(settings) {
    const response = await fetch("/edit/save", {
      method: "PUT",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify(settings),
    })
    if (response.ok) {
      alert("Settings saved successfully");
    } else {
      alert("Failed to save settings.");
    }
  }

  // @ts-expect-error
  window.handleImageUpload = async function(event) {
    const file: File = event.files[0];
    const response = await fetch("/edit/image", {
      method: "PUT",
      headers: {
        "Content-Type": file.type,
      },
      body: file,
    });
    const json = await response.json<{ path: string }>();
    window.dispatchEvent(new CustomEvent("image-uploaded", { detail: json }))
  }
</script>