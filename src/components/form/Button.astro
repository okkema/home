---
interface Props {
    label: string
    key: string
    type?: "Primary" | "Secondary"
    onClick: string
}
const { label, key, onClick, type = "Primary" } = Astro.props;
const classes = type == "Primary" ? "bg-blue-600 hover:bg-blue-700 text-white" : "bg-gray-200 hover:bg-gray-300 text-gray-800";
---
<button id={key} type="button" @click={onClick} class={`font-bold py-2 px-4 rounded transition-colors text-xs ${classes}`}>{label}</button>
