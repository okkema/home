---
interface Props {
    label: string
    key: string
}
const { label, key } = Astro.props;
---
<label class="flex items-center gap-2 cursor-pointer">
    <input type="checkbox" id={key} name={key} x-model={key} class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" /> {label}
</label>
