---
interface Props {
    label: string
    key: string
    onChange?: string
}
const { label, key, onChange } = Astro.props;
---
<div class="flex flex-col gap-1">
    <label class="font-bold text-gray-700">{label}</label>
    <input type="file" id={key} name={key} @change={onChange} class="text-xs file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-xs file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
</div>