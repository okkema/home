---
interface Props {
    label: string
    key: string
    required?: boolean
}
const { label, key, required } = Astro.props;
---
<div class="flex flex-col gap-1">
    <label class="font-bold text-gray-700">{label} {required ? <span class="text-red-500">*</span> : ""}</label>
    <textarea rows="3" id={key} name={key} x-model={key} class="w-full border border-gray-300 rounded px-3 py-2 focus:ring-1 focus:ring-blue-500 outline-none"></textarea>
</div>
